///|
fn glyph_index_ascii(ch : Char) -> Int {
  let code = ch.to_int()
  if code < 32 || code > 126 {
    63 - 32
  } else {
    code - 32
  }
}

///|
pub fn text_width(text : String, scale? : Int = 1) -> Int {
  if scale <= 0 {
    return 0
  }
  let mut count = 0
  for _ in text {
    count += 1
  }
  if count <= 0 {
    0
  } else {
    count * 6 * scale - scale
  }
}

///|
pub fn draw_text(
  frame : Frame,
  x : Int,
  y : Int,
  text : String,
  color : Int,
  scale? : Int = 1,
) -> Unit {
  if scale <= 0 {
    return
  }

  let mut pen_x = x
  for ch in text {
    let cols = glyphs_5x7_ascii[glyph_index_ascii(ch)]
    for col_idx in 0..<5 {
      let bits = cols[col_idx]
      for row_idx in 0..<7 {
        if (bits & (1 << row_idx)) != 0 {
          frame.draw_rect(
            pen_x + col_idx * scale,
            y + row_idx * scale,
            scale,
            scale,
            color,
          )
        }
      }
    }
    pen_x += 6 * scale
  }
}
